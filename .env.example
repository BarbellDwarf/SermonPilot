# SermonPilot Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: SermonAudio API credentials
SERMONAUDIO_API_KEY=your-sermonaudio-api-key
SERMONAUDIO_BROADCASTER_ID=your-broadcaster-id

# Optional: LLM provider API keys (set at least one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Optional: Ollama host (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Optional: OpenAI-compatible base URL override
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: GPU backend (cpu, cuda, rocm)
GPU_BACKEND=cpu
